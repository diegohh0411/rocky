# ===== Core =====
OPENCODE_SERVER_PASSWORD=

# ===== AI Provider Auth (export from your dev machine) =====
# Get these by running on your dev machine:
#   base64 ~/.local/share/opencode/auth.json | tr -d '\n'
#   base64 ~/.local/share/opencode/mcp-auth.json | tr -d '\n'
OPENCODE_AUTH_JSON_BASE64=
OPENCODE_MCP_AUTH_JSON_BASE64=

# ===== Notion MCP =====
NOTION_TOKEN=

# ===== GitHub =====
GH_TOKEN=

# ===== Cloudflare Tunnel =====
CLOUDFLARE_TUNNEL_TOKEN=
TUNNEL_HOSTNAME=opencode.yourdomain.com

# ===== Firecrawl =====
FIRECRAWL_OPENAI_API_KEY=

# ===== VM User =====
# The user account that runs `docker compose up` on the VM.
# This user's ~/.ssh, ~/.gitconfig, ~/.config/gh, and ~/.supabase
# will be bind-mounted into the opencode container for git/SSH access.
VM_USER=rocky-svc